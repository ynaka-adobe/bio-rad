            "da": {
              "name": "advanced-tabs",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "content",
                  "selector": "div:nth-child(1)"
                }
              ]
            }
          }
        },
        {
          "title": "Card",
          "id": "card",
          "model": "card",
          "plugins": {
            "da": {
              "name": "card",
