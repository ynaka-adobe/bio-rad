{
  "groups": [
    {
      "title": "Default Content",
      "id": "default",
      "components": [
        {
          "title": "Text",
          "id": "text",
          "model": "text",
          "plugins": {
            "da": {
              "name": "text",
              "type": "text"
            }
          }
        },
        {
          "title": "Image",
          "id": "image",
          "model": "image",
          "plugins": {
            "da": {
              "name": "image",
              "type": "image",
              "fields": [
                {
                  "name": "image",
                  "selector": "img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "img[alt]"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "title": "Sections",
      "id": "sections",
      "components": [
        {
          "title": "Section",
          "id": "section",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>"
            }
          },
          "filter": "section",
          "model": "section"
        }
      ]
    },
    {
      "title": "Blocks",
      "id": "blocks",
      "components": [
        {
          "title": "Advanced Tabs",
          "id": "advanced-tabs",
          "model": "advanced-tabs",
          "plugins": {
            "da": {
              "name": "advanced-tabs",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "content",
                  "selector": "div:nth-child(1)"
                }
              ]
            }
          }
        },
        {
          "title": "Card",
          "id": "card",
          "model": "card",
          "plugins": {
            "da": {
              "name": "card",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "content",
                  "selector": "div:nth-child(1)"
                }
              ]
            }
          }
        },
        {
          "title": "Columns",
          "id": "columns",
          "model": "columns",
          "filter": "columns",
          "plugins": {
            "da": {
              "name": "columns",
              "rows": 1,
              "columns": 2,
              "behaviour": "columns"
            }
          }
        },
        {
          "title": "Columns Row",
          "id": "columns-row",
          "model": "columns-row",
          "filter": "columns-row",
          "plugins": {
            "da": {
              "name": "columns-row",
              "behaviour": "columns-row"
            }
          }
        },
        {
          "title": "Columns Cell",
          "id": "columns-cell",
          "model": "columns-cell",
          "filter": "columns-cell",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>",
              "behaviour": "columns-cell"
            }
          }
        },
        {
          "title": "Footer",
          "id": "footer",
          "model": "footer",
          "plugins": {
            "da": {
              "name": "footer",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "content",
                  "selector": "div:nth-child(1)"
                }
              ]
            }
          }
        },
        {
          "title": "Fragment",
          "id": "fragment",
          "model": "fragment",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"fragment\"><div><div><p><a href=\"\">Fragment URL</a></p></div></div></div>",
              "fields": [
                {
                  "name": "url",
                  "selector": "div>div>p>a[href]"
                },
                {
                  "name": "urlText",
                  "selector": "div>div>p>a"
                }
              ]
            }
          }
        },
        {
          "title": "Header",
          "id": "header",
          "model": "header",
          "plugins": {
            "da": {
              "name": "header",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "content",
                  "selector": "div:nth-child(1)"
                }
              ]
            }
          }
        },
        {
          "title": "Hero",
          "id": "hero",
          "model": "hero",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"hero\"><div><div><picture><source type=\"image/webp\" srcset=\"\"><source type=\"image/jpeg\" srcset=\"\"><img loading=\"lazy\"></picture><h1></h1></div></div></div>",
              "fields": [
                {
                  "name": "image",
                  "selector": "div>div>picture>img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div>div>picture>img[alt]"
                },
                {
                  "name": "text",
                  "selector": "div>div>h1"
                }
              ]
            }
          }
        },
        {
          "title": "Schedule",
          "id": "schedule",
          "model": "schedule",
          "plugins": {
            "da": {
              "name": "schedule",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "content",
                  "selector": "div:nth-child(1)"
                }
              ]
            }
          }
        },
        {
          "title": "Section Metadata",
          "id": "section-metadata",
          "model": "section-metadata",
          "plugins": {
            "da": {
              "name": "section-metadata",
              "type": "key-value-block"
            }
          }
        },
        {
          "title": "Table",
          "id": "table",
          "model": "table",
          "filter": "table",
          "plugins": {
            "da": {
              "name": "table",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "table",
                  "selector": "div>div"
                }
              ]
            }
          }
        },
        {
          "title": "Youtube",
          "id": "youtube",
          "model": "youtube",
          "plugins": {
            "da": {
              "name": "youtube",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "content",
                  "selector": "div:nth-child(1)"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}