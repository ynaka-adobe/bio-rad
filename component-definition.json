            "da": {
              "unsafeHTML": "<div></div>",
              "behaviour": "columns-cell"
            }
          }
        },
        {
          "title": "Footer",
          "id": "footer",
          "model": "footer",
          "plugins": {
            "da": {
              "name": "footer",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "content",
                  "selector": "div:nth-child(1)"
                }
              ]
            }
          }
        },
        {
          "title": "Fragment",
          "id": "fragment",
          "model": "fragment",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"fragment\"><div><div><p><a href=\"\">Fragment URL</a></p></div></div></div>",
              "fields": [
                {
                  "name": "url",
                  "selector": "div>div>p>a[href]"
                },
                {
                  "name": "urlText",
                  "selector": "div>div>p>a"
                }
              ]
            }
          }
        },
        {
          "title": "Header",
          "id": "header",
          "model": "header",
          "plugins": {
            "da": {
              "name": "header",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "content",
                  "selector": "div:nth-child(1)"
                }
              ]
            }
          }
        },
        {
          "title": "Hero Banner",
          "id": "hero-banner",
          "model": "hero-banner",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"hero-banner\"><div><div><picture><source type=\"image/webp\" srcset=\"\"><source type=\"image/jpeg\" srcset=\"\"><img loading=\"lazy\"></picture></div></div><div><div><h1></h1><p></p><p><a href=\"\">Learn More</a></p></div></div></div>",
              "fields": [
                {
                  "name": "image",
                  "selector": "div:first-child>div>picture>img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div:first-child>div>picture>img[alt]"
                },
                {
                  "name": "text",
                  "selector": "div:last-child>div"
                }
              ]
            }
          }
        },
        {
          "title": "Hero",
          "id": "hero",
          "model": "hero",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"hero\"><div><div><picture><source type=\"image/webp\" srcset=\"\"><source type=\"image/jpeg\" srcset=\"\"><img loading=\"lazy\"></picture></div></div><div><div><h1></h1></div></div></div>",
              "fields": [
                {
                  "name": "image",
                  "selector": "div:first-child>div>picture>img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div:first-child>div>picture>img[alt]"
                },
                {
                  "name": "text",
                  "selector": "div:last-child>div>h1"
                }
              ]
            }
          }
        },
        {
          "title": "Quote",
          "id": "quote",
          "model": "quote",
          "plugins": {
            "da": {
              "name": "quote",
              "unsafeHTML": "<div><div></div></div><div><div></div></div>",
              "fields": [
                {
                  "name": "quotation",
                  "selector": "div:first-child>div"
                },
                {
                  "name": "attribution",
                  "selector": "div:last-child>div"
                }
              ]
            },
            "xwalk": {
              "page": {
                "resourceType": "core/franklin/components/block/v1/block",
                "template": {
                  "name": "Quote",
                  "model": "quote"
                }
              }
            }
          }
        },
        {
          "title": "Schedule",
          "id": "schedule",
          "model": "schedule",
          "plugins": {
            "da": {
              "name": "schedule",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "content",
                  "selector": "div:nth-child(1)"
                }
              ]
            }
          }
        },
        {
          "title": "Section Metadata",
          "id": "section-metadata",
          "model": "section-metadata",
          "plugins": {
            "da": {
              "name": "section-metadata",
              "type": "key-value-block"
            }
          }
        },
        {
          "title": "Site search",
          "id": "site-search",
          "model": "site-search",
          "plugins": {
            "da": {
              "name": "site-search",
              "unsafeHTML": "<div><div><h2></h2></div></div><div><div><p><a href=\"/query-index.json\"></a></p></div></div><div><div><p>Search…</p></div></div>",
              "fields": [
                {
                  "name": "title",
                  "selector": "div:nth-child(1) h2"
                },
                {
                  "name": "titleType",
                  "selector": "div:nth-child(1) h2"
                },
                {
                  "name": "link",
                  "selector": "div:nth-child(2) a[href]"
                },
                {
                  "name": "placeholder",
                  "selector": "div:nth-child(3) p"
                }
              ]
            },
            "xwalk": {
              "page": {
                "resourceType": "core/franklin/components/block/v1/block",
                "template": {
                  "name": "Site search",
                  "model": "site-search"
                }
              }
            }
          }
        },
        {
          "title": "Table",
          "id": "table",
          "model": "table",
          "filter": "table",
          "plugins": {
            "da": {
              "name": "table",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "table",
                  "selector": "div>div"
                }
              ]
            }
          }
        },
        {
          "title": "Target offer",
          "id": "target-offer",
          "model": "target-offer",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"target-offer\"><span class=\"target-offer-export-id\" hidden></span><div class=\"target-offer-config\"><div><p class=\"target-offer-mbox\"></p></div></div><div class=\"target-offer-default\"><div><p>Default content</p></div></div></div>",
              "fields": [
                {
                  "name": "exportId",
                  "selector": "span.target-offer-export-id"
                },
                {
                  "name": "mboxName",
                  "selector": "p.target-offer-mbox"
                },
                {
                  "name": "content",
                  "selector": "div.target-offer-default"
                }
              ]
            }
          }
        },
